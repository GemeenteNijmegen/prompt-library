meta {
  name: Generate machine key
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/v1/auth/generate-key
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "scope": ["prompt:read", "prompt:create", "prompt:write", "prompt:publish"],
    "expires_in_days": 365
  }
}
