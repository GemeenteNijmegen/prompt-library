# Docker Compose profile: full | dev | simple  (see docker-compose.yml)
COMPOSE_PROFILES=full

# Database
DATABASE_URL=sqlite:///data/gallery.db

# JWT / Auth (see ADR 0003, ADR 0004).
#   In production: JWKS_URI + JWT_ISSUER are REQUIRED; JWT_SECRET_KEY is hard-blocked.
#   For Keycloak fill these as:
#     JWKS_URI     = https://<keycloak-host>/realms/<realm>/protocol/openid-connect/certs
#     JWT_ISSUER   = https://<keycloak-host>/realms/<realm>     (no trailing slash; must match `iss` claim exactly)
#     JWT_AUDIENCE = prompt-gallery-api                          (configure a Keycloak audience mapper to emit this)
#   In dev/test: leave JWKS_URI empty and set JWT_SECRET_KEY for the HS256 fallback path.
JWKS_URI=
JWT_ISSUER=
JWT_AUDIENCE=prompt-gallery-api
JWT_SECRET_KEY=dev-secret-change-me
JWKS_CACHE_TTL_SECONDS=3600
JWT_LEEWAY_SECONDS=60
DEV_STUB_TOKEN=dev-token

# Storage backend: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# S3 (only when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=eu-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Redis (optional caching layer; omit to use in-memory TTLCache)
REDIS_URL=

# Logging & environment
LOG_LEVEL=info
ENVIRONMENT=development

# Rate limiting (requests/minute). Multi-axis — request rejected if any bucket exceeded.
RATE_LIMIT_ANONYMOUS=30   # per IP
RATE_LIMIT_USER=120       # per End User (`sub`)
RATE_LIMIT_CLIENT=600     # per OAuth client (`azp`)
RATE_LIMIT_ORG=1200       # per Organisation (`org_id`)

# Upload limits
MAX_UPLOAD_SIZE=5242880
