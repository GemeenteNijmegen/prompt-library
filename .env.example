# Docker Compose profile: full | dev | simple  (see docker-compose.yml)
COMPOSE_PROFILES=full

# Database
DATABASE_URL=sqlite:///data/gallery.db

# JWT / Auth (production requires JWKS_URI; dev uses JWT_SECRET_KEY fallback)
JWKS_URI=
JWT_ISSUER=http://localhost:9000
JWT_SECRET_KEY=dev-secret-change-me
DEV_STUB_TOKEN=dev-token

# Storage backend: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# S3 (only when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=eu-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Redis (optional caching layer; omit to use in-memory TTLCache)
REDIS_URL=

# Logging & environment
LOG_LEVEL=info
ENVIRONMENT=development

# Rate limiting (requests/minute)
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_USER=120
RATE_LIMIT_MACHINE=300

# Upload limits
MAX_UPLOAD_SIZE=5242880
